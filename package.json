{
  "name": "tokenflow",
  "version": "0.2.5",
  "description": "Local token usage collector for multi-device AI agent accounting.",
  "type": "module",
  "bin": {
    "tokenflow": "dist/cli.js",
    "tokenusage": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "publish:npm": "node scripts/publish-dual-npm.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md",
    "THIRD_PARTY_NOTICES.md",
    "docs/assets/teaser_en.png",
    "docs/assets/teaser_zh.png",
    "docs/i18n"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.4",
    "vitest": "^1.6.0"
  }
}
